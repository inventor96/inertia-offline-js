{
  "name": "inertia-offline",
  "version": "0.4.1",
  "description": "Enable offline read-only support for Inertia.js-based PWAs",
  "keywords": [
    "inertia",
    "offline",
    "pwa",
    "vue"
  ],
  "license": "MIT",
  "author": "inventor96",
  "repository": {
    "url": "https://github.com/inventor96/inertia-offline-js"
  },
  "type": "module",
  "main": "index.ts",
  "files":[
    "dist"
  ],
  "exports": {
    ".": "./dist/core/index.js",
    "./vue": "./dist/vue/index.js",
    "./sw": "./dist/sw/index.js"
  },
  "types": "./dist/core/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vue": "^3.0.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "vite-plugin-pwa": {
      "optional": true
    }
  },
  "dependencies": {
    "dexie": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vue": "^3.0.0"
  }
}
